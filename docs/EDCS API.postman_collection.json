  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sanctum",
          "item": [
            {
              "name": "/auth/register",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"CMDR Example\",\n  \"email\": \"cmdr@example.com\",\n  \"password\": \"password\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{url}}/auth/register",
                  "host": ["{{url}}"],
                  "path": ["auth", "register"]
                }
              },
              "response": []
            },
            {
              "name": "/auth/login",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"cmdr@example.com\",\n  \"password\": \"password\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{url}}/auth/login",
                  "host": ["{{url}}"],
                  "path": ["auth", "login"]
                }
              },
              "response": []
            },
            {
              "name": "/auth/logout",
              "request": {
                "method": "POST",
                "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
                "url": {
                  "raw": "{{url}}/auth/logout",
                  "host": ["{{url}}"],
                  "path": ["auth", "logout"]
                }
              },
              "response": []
            },
            {
              "name": "/auth/me",
              "request": {
                "method": "GET",
                "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
                "url": {
                  "raw": "{{url}}/auth/me",
                  "host": ["{{url}}"],
                  "path": ["auth", "me"]
                }
              },
              "response": []
            }
          ],
          "description": "Sanctum token-based auth for direct API or admin access."
        },
        {
          "name": "Frontier",
          "item": [
            {
              "name": "/auth/frontier/login",
              "request": {
                "auth": { "type": "noauth" },
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{url}}/auth/frontier/login",
                  "host": ["{{url}}"],
                  "path": ["auth", "frontier", "login"]
                },
                "description": "Returns the Frontier OAuth authorization URL and PKCE parameters. The frontend redirects the user to the authorization_url."
              },
              "response": []
            },
            {
              "name": "/auth/frontier/callback",
              "request": {
                "auth": { "type": "noauth" },
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{url}}/auth/frontier/callback?code=AUTH_CODE&state=STATE_STRING",
                  "host": ["{{url}}"],
                  "path": ["auth", "frontier", "callback"],
                  "query": [
                    {
                      "key": "code",
                      "value": "AUTH_CODE",
                      "description": "Authorization grant code returned by Frontier"
                    },
                    {
                      "key": "state",
                      "value": "STATE_STRING",
                      "description": "State string originally sent in the authorization request — used to retrieve the cached code verifier"
                    }
                  ]
                },
                "description": "Frontier redirects here after the user approves. Exchanges the code for tokens, upserts the user and commander, issues a Sanctum token, and redirects to the frontend with the cmdr_token HttpOnly cookie."
              },
              "response": []
            },
            {
              "name": "/auth/frontier/me",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{url}}/auth/frontier/me",
                  "host": ["{{url}}"],
                  "path": ["auth", "frontier", "me"]
                },
                "description": "Called by the frontend immediately after the OAuth callback. Reads the cmdr_token HttpOnly cookie to identify the user and returns their user and commander data alongside the plain-text Sanctum token for NextAuth to store in its session."
              },
              "response": []
            },
            {
              "name": "CAPI",
              "item": [
                {
                  "name": "/frontier/capi/profile",
                  "request": {
                    "method": "GET",
                    "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
                    "url": {
                      "raw": "{{url}}/frontier/capi/profile",
                      "host": ["{{url}}"],
                      "path": ["frontier", "capi", "profile"]
                    },
                    "description": "Fetches the live commander profile from Frontier CAPI and updates the stored commander record. Automatically refreshes the Frontier access token if it has expired."
                  },
                  "response": []
                },
                {
                  "name": "/frontier/capi/journal",
                  "request": {
                    "method": "GET",
                    "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
                    "url": {
                      "raw": "{{url}}/frontier/capi/journal",
                      "host": ["{{url}}"],
                      "path": ["frontier", "capi", "journal"],
                      "query": [
                        {
                          "key": "year",
                          "value": "2025",
                          "description": "Journal year (optional — omit for today)",
                          "disabled": true
                        },
                        {
                          "key": "month",
                          "value": "04",
                          "description": "Journal month (optional)",
                          "disabled": true
                        },
                        {
                          "key": "day",
                          "value": "26",
                          "description": "Journal day (optional)",
                          "disabled": true
                        }
                      ]
                    },
                    "description": "Returns the commander's journal entries for the given date (or today if no date is provided). Automatically refreshes the Frontier access token if expired."
                  },
                  "response": []
                },
                {
                  "name": "/frontier/capi/communitygoals",
                  "request": {
                    "method": "GET",
                    "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
                    "url": {
                      "raw": "{{url}}/frontier/capi/communitygoals",
                      "host": ["{{url}}"],
                      "path": ["frontier", "capi", "communitygoals"]
                    },
                    "description": "Returns all currently active community goals and any contributions from this commander."
                  },
                  "response": []
                }
              ],
              "description": "Frontier Companion API endpoints. All require a valid Sanctum token. The Frontier access token is resolved and refreshed automatically server-side."
            }
          ],
          "description": "Frontier OAuth2 PKCE flow and CAPI proxy endpoints."
        }
      ]
    },
    {
      "name": "Commander",
      "item": [
        {
          "name": "/commander",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inara_api_key\": \"your-inara-key\",\n  \"edsm_api_key\": \"your-edsm-key\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{url}}/commander",
              "host": ["{{url}}"],
              "path": ["commander"]
            },
            "description": "Updates the authenticated commander's third-party API keys. Both fields are optional and nullable."
          },
          "response": []
        }
      ]
    },
